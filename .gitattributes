# Treat binary assets as binary so Git never applies CRLF/LF line-ending
# conversion to them (which would corrupt PDFs, images, models, fonts).
*.pdf  binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.glb  binary
*.gltf binary
*.woff  binary
*.woff2 binary
*.ttf  binary
*.otf  binary
*.mp4  binary
*.webm binary
